# Archimede RUI Variabili d'ambiente
# Copia questo file in .env e inserisci le tue configurazioni.

# LLM API Key (per reasoning core)
# Provider supportati: deepseek, openai, anthropic, ollama
# deepseek: https://api.deepseek.com/v1
# openai:    https://api.openai.com/v1
# anthropic: https://api.anthropic.com
# ollama:    http://localhost:11434/v1 (non richiede chiave)
ARCHIMEDE_API_KEY=

# Path Penelope
# Directory dove si trova Penelope (relativa o assoluta)
# Default: ../penelope (sibling directory)
ARCHIMEDE_PENELOPE_PATH=../penelope

# ChromaDB
ARCHIMEDE_CHROMA_PATH=data/chroma

# Config YAML
# Opzionale. Default: ./config/default.yaml
# ARCHIMEDE_CONFIG=./config/production.yaml