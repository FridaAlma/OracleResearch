# Penelope RUI Configurazione
# Copia questo file in .env e modifica i valori per il tuo ambiente.
#
# Per usare Docker MariaDB (consigliato):
#   1. docker-compose up -d        (dalla root di oracle-rui-edition)
#   2. Lascia i default qui sotto (localhost:3306)
#
# Per usare SQLite (zero setup, single-user):
#   PENELOPE_DB_BACKEND=sqlite

# Database 

# Backend: "mariadb" (default) o "sqlite" (locale, nessun server richiesto)
PENELOPE_DB_BACKEND=mariadb

# MariaDB (default: Docker locale)
PENELOPE_DB_HOST=localhost
PENELOPE_DB_PORT=3306
PENELOPE_DB_USER=penelope
PENELOPE_DB_NAME=penelope_rui
# Password: usa variabile d'ambiente o keyring (vedi SETUP.md)
# PENELOPE_DB_PASSWORD=penelope_rui_pass

# SQLite (se PENELOPE_DB_BACKEND=sqlite)
PENELOPE_SQLITE_PATH=data/penelope.db

# Storage paths da scandire 
# Configura fino a 5 directory/dispositivi da indicizzare.
# Lascia vuoto per non scansionare.
PENELOPE_STORAGE_1=C:/Users/Documenti
PENELOPE_STORAGE_2=
PENELOPE_STORAGE_3=
PENELOPE_STORAGE_4=
PENELOPE_STORAGE_5=

# ChromaDB 
PENELOPE_CHROMA_PATH=data/chroma

# Face Recognition 
PENELOPE_EMBEDDINGS=data/embeddings

# Altro 
PENELOPE_LOG_LEVEL=INFO
PENELOPE_SCAN_BATCH_SIZE=1000