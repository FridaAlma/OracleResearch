# =============================================================================
# Oracle - AI Coding Agent - Configuration
# =============================================================================
# COPY THIS FILE TO .env AND FILL IN YOUR VALUES
# THIS FILE (.env.example) SHOULD BE COMMITTED TO VERSION CONTROL
# THE .env FILE SHOULD NOT BE COMMITTED (it's in .gitignore)
# =============================================================================

# -----------------------------------------------------------------------------
# Model Configuration
# -----------------------------------------------------------------------------
# Provider del modello: openai, deepseek, openrouter, google, anthropic,
# ollama, together, groq, mistral, cohere, fireworks, perplexity, xai,
# cerebras, nebius, sambanova, github, azure, vllm, e molti altri.
# Per una lista completa, vedi model_factory.py -> PROVIDER_REGISTRY.
MODEL_PROVIDER=openai

# Model ID per tier flash (default) e pro
MODEL_ID=gpt-4o-mini
MODEL_PRO_ID=gpt-4o

# Tier: auto | flash | pro
#   auto  = rilevamento automatico in base al contenuto del messaggio
#   flash = usa sempre MODEL_ID
#   pro   = usa sempre MODEL_PRO_ID
MODEL_TIER=auto

# API key del provider
API_KEY=your-api-key-here

# Base URL (solo per provider OpenAI-compatible)
# Lascia vuoto per usare l'URL predefinito del provider.
# Esempi:
#   openrouter  https://openrouter.ai/api/v1
#   deepseek    https://api.deepseek.com
#   together    https://api.together.xyz/v1
API_BASE_URL=

# Limiti
MAX_TOKENS=16384
REQUEST_TIMEOUT=300

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
HOST=127.0.0.1                     # IP su cui ascoltare (127.0.0.1 per sicurezza)
PORT=8000                          # Porta del server

# -----------------------------------------------------------------------------
# Authentication Configuration (NEW)
# -----------------------------------------------------------------------------
# JWT Secret Key - Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
AUTH_SECRET_KEY=your-jwt-secret-key-here-generate-with-python-secrets-token-urlsafe-32

# Token expiration
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Default admin user (created on first run if users table is empty)
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_EMAIL=admin@oracle.local
DEFAULT_ADMIN_PASSWORD=your-strong-admin-password-here

# User database path
USERS_DB_PATH=data/users.db

# -----------------------------------------------------------------------------
# Security Configuration
# -----------------------------------------------------------------------------
# CORS Settings
CORS_ORIGINS=http://localhost,http://localhost:8000,http://127.0.0.1,http://127.0.0.1:8000
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_WILDCARD=false      # Set to true only for development

# Security Headers
SECURITY_ENABLE_HSTS=false       # Enable only in production with HTTPS
SECURITY_ENABLE_CSP=false        # Enable Content Security Policy
SECURITY_ENABLE_X_FRAME_OPTIONS=true
SECURITY_X_FRAME_OPTIONS=DENY

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_AUTHENTICATED=1000/minute
RATE_LIMIT_AUTH_ENDPOINTS=10/hour
RATE_LIMIT_STORAGE=memory      # memory or redis
RATE_LIMIT_WHITELIST=127.0.0.1,::1  # IPs not subject to rate limiting

# Redis Configuration (for rate limiting storage)
RATE_LIMIT_REDIS_HOST=localhost
RATE_LIMIT_REDIS_PORT=6379
RATE_LIMIT_REDIS_PASSWORD=
RATE_LIMIT_REDIS_DB=0

# -----------------------------------------------------------------------------
# Shell Command Configuration
# -----------------------------------------------------------------------------
# Enable/disable dangerous shell commands
SHELL_ENABLED=true
SHELL_TIMEOUT=30                  # Timeout in seconds for shell commands
SHELL_SANDBOX_ENABLED=false       # Enable sandbox for shell commands
DANGEROUS_TOOLS_ENABLED=false     # Enable tools that can modify system

# -----------------------------------------------------------------------------
# Logging Configuration
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_ENABLE_CONSOLE=true
LOG_ENABLE_FILE=false
LOG_FILE_PATH=logs/oracle.log

# -----------------------------------------------------------------------------
# Proxy Configuration (if behind reverse proxy)
# -----------------------------------------------------------------------------
PROXY_ENABLED=false
TRUSTED_HOSTS=localhost,127.0.0.1,0.0.0.0
ALLOW_ALL_HOSTS=false

# -----------------------------------------------------------------------------
# Vector Memory Configuration
# -----------------------------------------------------------------------------
CHROMA_DB_PATH=data/vector_memory
